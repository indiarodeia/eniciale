# Desactivar listagem de diretórios
Options -Indexes

RewriteEngine On

# ------------------------------------------------------------------
# 1) Canonical: HTTPS + domínio sem www (https://eniciale.pt)
# ------------------------------------------------------------------
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} !^eniciale\.pt$ [NC]
RewriteRule ^(.*)$ https://eniciale.pt/$1 [L,R=301]

# ------------------------------------------------------------------
# 2) Remover .html da URL (exclui 404.html e index.html)
#    - /sobre.html  -> /sobre
# ------------------------------------------------------------------
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteCond %1 !^(404|index)$ [NC]
RewriteRule ^ /%1 [R=301,L]

# ------------------------------------------------------------------
# 3) Permitir aceder sem extensão (exclui /404)
#    - /sobre   -> carrega /sobre.html
# ------------------------------------------------------------------
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !^/404/?$ [NC]
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# ------------------------------------------------------------------
# 4) Página 404 personalizada (na raiz)
# ------------------------------------------------------------------
ErrorDocument 404 /404.html
